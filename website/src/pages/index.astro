---
import "../styles/global.css"

import SiteLayout from "../layouts/layout.astro"
import PollCardTemplate from "../components/index/poll-card.astro"
---

<SiteLayout title="Enfield NH Zoning">
    <div class="stack" id="contents">
        <h2>Current Polls - June Batch</h2>
        <PollCardTemplate id="template" />
    </div>
</SiteLayout>

<script>
    import $ from "jquery"
    import type { HomeModel } from "@enfield-zoning/website-api-dto"
    import { fetchGet } from "../scripts/fetch"
    import { createPollCard } from "../scripts/index/poll-card"

    async function loadCards() {
        const data = await fetchGet<HomeModel>("home")

        // Display the data
        const template = $("template")
        const stack = $("#contents")

        if (data == null) {
            stack.html("")
        } else {
            for (let card of data.cards) {
                const newCard = createPollCard(template, card)
                stack.append(newCard)
            }
        }
    }

    loadCards()
</script>