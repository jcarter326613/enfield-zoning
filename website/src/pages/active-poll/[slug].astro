---
export async function getStaticPaths() {
    return [
        { params: { slug: "one-primary-building" } },
    ]
}

import "../../styles/active-poll.css"

import SiteLayout from "../../layouts/layout.astro"
import SignInButton from "../../components/sign-in-button.astro"
---

<SiteLayout title="Enfield NH Zoning Poll">
    <div id="summary-div">
        <h2>Summary</h2>
        <div class="contents"></div>
    </div>
    <div id="actual-change-div">
        <h2>Actual Change</h2>
        <div class="contents"></div>
    </div>
    <div id="voting-block" style="display:none;">
        <h2>Vote here</h2>
        <div class="contents logged-in">
            <div class="question"></div>
            <div class="options"></div>
            <sub>You may change your selection as many times as you like before the poll closes.</sub>
        </div>
        <div class="contents voting-not-allowed">
            <div>In order to participate in the poll, you must tell us who you are.</div>
            <div><button id="start-submit-identity">Submit Identity</button></div>
        </div>
        <div class="contents logged-out">
            <div>You must be signed in and identified to participate in polling.</div>
            <div>
                <SignInButton redirectUrl="/active-poll" />
            </div>
        </div>
        <div class="contents expired">
            <div>The response period for this question has expired.  We are compiling results and will post them as soon as possible.</div>
        </div>
    </div>
    <div id="identity-submission" style="display:none;">
        <h2>Voting permission registration</h2>
        <div>
            <p>Please provide the following information to show you are an Enfield resident.  Provide your legal 
                name and street as it would appear on your voter registration or other official documentation.</p>
            <div>
                <label for="identity-name">
                    Legal Name
                    <input id="identity-name" type="text" />
                </label>
            </div>
            <div>
                <label for="identity-street">
                    Domicile Street
                    <input id="identity-street" type="text" />
                </label>
            </div>
            <div id="identity-error" class="error-message" style="display:none;"></div>
            <div>
                <button id="submit-identity">Submit</button>
            </div>
        </div>
    </div>
</SiteLayout>

<script>
    import $ from "jquery"
    import type { 
        Account,
        Poll,
    } from "@enfield-zoning/website-api-dto"

    import { fetchGet, fetchPost } from "../../scripts/fetch"
    import { markdownToHtml } from "../../scripts/markdown"

    function connectButtons() {
        $("#start-submit-identity").on("click", () => {
            $("#identity-submission").show()
        })
        $("#submit-identity").on("click", submitIdentity)
    }

    async function loadPage() {
        const slug = location.pathname.split("/").filter(Boolean).pop()
        const infoModel = await fetchGet<Poll.ActivePollResponse>(`active-poll/${slug}`)
        
        if (infoModel == null) {
            window.location.href = "/"
            return
        }

        // Get the handles to the render locations
        const summaryDiv = $("#summary-div .contents")
        const actualChangeDiv = $("#actual-change-div .contents")
        const votingBlock = $("#voting-block")

        // Clear out the current contents
        votingBlock.hide()
        summaryDiv.html("")
        actualChangeDiv.html("")

        // If the poll is a zoning ammendment, populate that
        if (infoModel != null && infoModel.type == "zoning-ammendment") {
            votingBlock.show()
            summaryDiv.html(markdownToHtml(infoModel.summaryMarkdown))
            actualChangeDiv.html(markdownToHtml(infoModel.zoningText))

            // Get ready to display the voting section    
            const votingExpiredBlock = $(".expired", votingBlock)
            const votingLoggedInBlock = $(".logged-in", votingBlock)
            const votingLoggedOutBlock = $(".logged-out", votingBlock)
            const votingNotAllowedBlock = $(".voting-not-allowed", votingBlock)

            votingExpiredBlock.hide()
            votingLoggedInBlock.hide()
            votingLoggedOutBlock.hide()
            votingNotAllowedBlock.hide()

            if (infoModel.poll.isExpired) {
                votingExpiredBlock.show()
            } else if (!infoModel.poll.loggedIn) {
                votingLoggedOutBlock.show()
            } else if (!infoModel.poll.allowedToVote) {
                votingNotAllowedBlock.show()
            } else {
                votingLoggedInBlock.show()

                // Populate the options
                const votingQuestionDiv = $(".options", votingLoggedInBlock)
                votingQuestionDiv.html("")
                infoModel.poll.votingOptions.forEach((value, index) => {
                    const id = `voting-option-${index}`

                    const input = $("<input>")
                        .attr("type", "radio")
                        .attr("id", id)
                        .attr("name", "vote")
                        .attr("value", value.value)
                    if (value.selected) {
                        input.attr("checked", "checked")
                    }
                    input.on("change", async () => {
                        await fetchPost<Poll.CastVote, void>(`active-poll/${slug}/cast-vote`, {
                            selectedValue: value.value
                        })
                    })

                    const label = $("<label>")
                        .attr("for", id)
                        .append(input)
                        .append(value.label)

                    votingQuestionDiv.append(label)
                })

                // Populate the question
                const votingAnswersDiv = $(".question", votingLoggedInBlock)
                votingAnswersDiv.html(markdownToHtml(infoModel.poll.votingQuestion))
            }
        }
    }

    async function submitIdentity() {
        const formDiv = $("#identity-submission")
        const nameInput = $("#identity-name", formDiv)
        const streetInput = $("#identity-street", formDiv)
        const errorDiv = $("#identity-error", formDiv)

        const legalName = String(nameInput.val()).trim()
        const legalStreet = String(streetInput.val()).trim()

        errorDiv.hide().text("")

        if (legalName.length === 0 || legalStreet.length === 0) {
            errorDiv
                .text("Legal name and domicile street are required.")
                .show()

            return
        }

        await fetchPost<Account.SubmitIdentity, void>("account/submit-identity", {
            legalName,
            legalStreet
        })

        $("#identity-submission").hide()
        loadPage()
    }

    connectButtons()
    loadPage()
</script>