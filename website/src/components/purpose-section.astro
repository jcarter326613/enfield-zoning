---
import "../styles/global.css"
---

<purpose-section>
    <h2 class="section-title">What is this for?</h2>
    <p>
        This site is an experiment to improve decision making around zoning amendments
        and give a stronger voice to people who don't have time to attend public meetings.
        The test is meant to see how much engagement an online forum like this can generate.
    </p>

    <p>
        The test has now been completed successfully.  We will now work on building out a
        complete working site.  When it is completed, we will notify the Enfield
        listserve.  Thank you for participating in this test.
    </p>

    <h3>Results</h3>
    <p>
        The results of the poll are as follows.  These results are similar to the actual
        voting results.  The question was, "How did you vote in the March 8 election on
        Article 2 (the zoning amendment)?"
    </p>

    <p>
        Results:
        <ul>
            <li>Yes - 19</li>
            <li>No - 22</li>
            <li>Did not vote on article 2 - 7</li>
        </ul>
        58 people clicked the button to start the poll after reaching this site.
        Of those 58, 48 actually answered the poll.
    </p>

    <!--
    <p>
        Please click the button below to answer a one question, multiple choice survey.
        Responses are completely anonymous.
    </p>

    <div class="cta-row">
        <button class="button button-primary button-cta" type="button">
            Take the survey
        </button>
    </div>
    -->
</purpose-section>

<script>
    import { postTraffic } from "../scripts/post-traffic"
    
    class PurposeSection extends HTMLElement {
        connectedCallback() {
            const button = this.querySelector("button")
            button?.addEventListener("click", () => {
                button.dispatchEvent(
                    new CustomEvent("startPoll", {
                        bubbles: true
                    })
                )

                postTraffic("startPoll")
            })

            postTraffic("displayPurpose")
        }
    }

    customElements.define("purpose-section", PurposeSection)
</script>
