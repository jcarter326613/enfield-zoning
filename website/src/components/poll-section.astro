---
import "../styles/global.css"
---

<poll-section>
    <h2 class="section-title">Survey question</h2>
    <p>
        How did you vote in the March 8 election on Article 2 (the zoning amendment)?
    </p>

    <div class="poll-options">
        <label class="poll-option">
            <input type="radio" name="pollChoice" value="yes" />
            <span class="poll-option-label">
                <span class="poll-option-title">Yes</span>
            </span>
        </label>

        <label class="poll-option">
            <input type="radio" name="pollChoice" value="no" />
            <span class="poll-option-label">
                <span class="poll-option-title">No</span>
            </span>
        </label>

        <label class="poll-option">
            <input type="radio" name="pollChoice" value="absent" />
            <span class="poll-option-label">
                <span class="poll-option-title">Did not vote</span>
                <span class="poll-option-description">
                    Choose this if you either skipped Article 2 or did not vote at all.
                </span>
            </span>
        </label>

        <div class="cta-row">
            <button class="button button-primary" type="submit">
                Submit
            </button>
        </div>
    </div>
</poll-section>

<script>
    import { postTraffic } from "../scripts/post-traffic"

    class PollSection extends HTMLElement {
        connectedCallback() {
            const button = this.querySelector("button")
            button?.addEventListener("click", () => {
                const selected = this.querySelector<HTMLInputElement>(
                    "input[name='pollChoice']:checked"
                )

                if (!selected) {
                    alert("Please select an option before submitting.")
                    return
                }

                const value = selected.value

                postTraffic("completePoll", value)
                .finally(() =>
                    button.dispatchEvent(
                        new CustomEvent("completePoll", {
                            bubbles: true
                        })
                ))
            })
        }
    }

    customElements.define("poll-section", PollSection)
</script>