---
interface Props {
    title?: string;
}

const { title = "Enfield NH Zoning" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <meta
            name="description"
            content="A community website for discussion, education, and public input on zoning topics in Enfield, New Hampshire."
        />
    </head>
    <body>
        <div class="site-shell">
            <header class="hero">
                <p class="eyebrow">Enfield, New Hampshire</p>
                <h1>Community conversation around zoning.</h1>
                <p>
                    A privately operated public-facing site for discussion, explanation,
                    and preference indication on zoning topics affecting Enfield.
                </p>
                <span class="hero-note">Independent civic information project</span>
            </header>

            <main class="main-grid">
                <section class="content-card">
                    <slot />
                </section>
            </main>

            <footer>
                This is not an official municipal website.
            </footer>
        </div>
    </body>
</html>

<style>
	:root {
		color-scheme: light;
		--bg: #f4f1ea;
		--panel: rgba(255, 255, 255, 0.92);
		--panel-strong: #ffffff;
		--text: #213028;
		--muted: #5b6d63;
		--border: rgba(33, 48, 40, 0.12);
		--accent: #2f5d50;
		--accent-dark: #254a40;
		--accent-soft: #dbe7de;
		--shadow: 0 16px 40px rgba(24, 38, 32, 0.12);
		--max-width: 1120px;
		--radius: 20px;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		font-family: Georgia, "Times New Roman", serif;
		background: var(--bg);
		color: var(--text);
	}

	body {
		min-height: 100vh;
		line-height: 1.5;
		background:
			linear-gradient(rgba(244, 241, 234, 0.58), rgba(244, 241, 234, 0.88)),
			url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80")
				center / cover no-repeat fixed;
	}

	a {
		color: inherit;
	}

	.site-shell {
		width: min(calc(100% - 2rem), var(--max-width));
		margin: 0 auto;
		padding: 2rem 0 4rem;
	}

	.hero {
		display: grid;
		gap: 1.25rem;
		padding: 3.5rem 2rem 2.5rem;
		border-radius: 28px;
		background:
			linear-gradient(135deg, rgba(20, 33, 28, 0.68), rgba(47, 93, 80, 0.48)),
			url("https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=1600&q=80")
				center / cover no-repeat;
		color: #f8f7f3;
		box-shadow: var(--shadow);
		overflow: hidden;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.8rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		opacity: 0.88;
	}

	.hero h1 {
		margin: 0;
		font-size: clamp(2.1rem, 4vw, 4rem);
		line-height: 1.05;
		max-width: 12ch;
	}

	.hero p {
		margin: 0;
		max-width: 48rem;
		font-size: 1.05rem;
		color: rgba(248, 247, 243, 0.92);
	}

	.hero-note {
		display: inline-block;
		width: fit-content;
		margin-top: 0.5rem;
		padding: 0.6rem 0.9rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.14);
		backdrop-filter: blur(6px);
		font-size: 0.95rem;
	}

	.main-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.75fr) minmax(280px, 0.85fr);
		gap: 1.5rem;
		margin-top: 1.5rem;
		align-items: start;
	}

	.content-card,
	.side-card {
		background: var(--panel);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		box-shadow: var(--shadow);
		backdrop-filter: blur(10px);
	}

	.content-card {
		padding: 1.5rem;
		min-height: 28rem;
	}

	.side-card {
		padding: 1.25rem;
	}

	.side-card h2 {
		margin: 0 0 0.75rem;
		font-size: 1.1rem;
	}

	.side-card p,
	.side-card li {
		color: var(--muted);
		font-size: 0.98rem;
	}

	.side-card ul {
		margin: 0;
		padding-left: 1.15rem;
	}

	.stack {
		display: grid;
		gap: 1rem;
	}

	.section-card {
		padding: 1.5rem;
		border-radius: 18px;
		background: var(--panel-strong);
		border: 1px solid var(--border);
	}

	.section-card h2,
	.section-card h3 {
		margin-top: 0;
		line-height: 1.15;
	}

	.section-card p:last-child {
		margin-bottom: 0;
	}

	.button-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1.25rem;
	}

	.button {
		appearance: none;
		border: 0;
		border-radius: 999px;
		padding: 0.85rem 1.15rem;
		font: inherit;
		cursor: pointer;
		transition:
			transform 0.15s ease,
			background 0.15s ease,
			opacity 0.15s ease;
	}

	.button:hover {
		transform: translateY(-1px);
	}

	.button-primary {
		background: var(--accent);
		color: #fff;
	}

	.button-primary:hover {
		background: var(--accent-dark);
	}

	.button-secondary {
		background: var(--accent-soft);
		color: var(--accent-dark);
	}

	.poll-options {
		display: grid;
		gap: 0.85rem;
		margin: 1rem 0 0;
	}

	.poll-option {
		display: flex;
		gap: 0.85rem;
		align-items: flex-start;
		padding: 0.95rem 1rem;
		border: 1px solid var(--border);
		border-radius: 14px;
		background: #fbfbf8;
	}

	.poll-option input {
		margin-top: 0.2rem;
	}

	.poll-option-label {
		display: grid;
		gap: 0.15rem;
	}

	.poll-option-title {
		font-weight: 700;
	}

	.poll-option-description {
		color: var(--muted);
		font-size: 0.95rem;
	}

	.fine-print {
		color: var(--muted);
		font-size: 0.92rem;
	}

	footer {
		margin-top: 1.5rem;
		padding: 0.25rem 0.5rem;
		color: var(--muted);
		font-size: 0.92rem;
	}

	@media (max-width: 900px) {
		.main-grid {
			grid-template-columns: 1fr;
		}

		.content-card {
			min-height: auto;
		}

		.hero {
			padding: 2.25rem 1.25rem 1.75rem;
		}
	}
</style>