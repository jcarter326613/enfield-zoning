---
import "../styles/global.css"

import SignInButton from "../components/sign-in-button.astro"

interface Props {
    title?: string
}

const { title = "Enfield NH Zoning" } = Astro.props
const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <meta
            name="description"
            content="A community website for discussion, education, and public input on zoning topics in Enfield, New Hampshire."
        />
    </head>
    <body>
        <div class="site-shell">
            <header class="site-header">
                <div>
                    <h1><a href="/">Enfield NH Zoning</a></h1>
                </div>

                <nav class="auth-actions" aria-label="Account actions">
                    {(currentPath == "/sign-in") ? <></> : 
                        <SignInButton redirectUrl={
                            (
                                currentPath != "/" &&
                                currentPath != "/complete-sign-in" &&
                                currentPath != "/sign-in-sent" &&
                                currentPath != "/sign-up" &&
                                currentPath != "/sign-up-validation"
                            ) ? currentPath : undefined} />
                    }
                    {(currentPath == "/sign-up") ? <></> : 
                        <a class="button-primary create" href="/sign-up">Create account</a>
                    }
                    <button class="button-primary logout" type="button">Logout</button>
                    <a class="button-secondary admin" href="/admin/comments">Admin</a>
                </nav>
            </header>

            <main class="content-wrap">
                <section class="content-card">
                    <slot />
                </section>
            </main>

            <footer class="site-footer">
                This is an independent website and not an official town website.
            </footer>
        </div>
    </body>
</html>

<script>
    import $ from "jquery"
    import type { Account } from "@enfield-zoning/website-api-dto"

    import { fetchGet } from "../scripts/fetch"

    const signinButton = $(".auth-actions .signin")
    const createButton = $(".auth-actions .create")
    const logoutButton = $(".auth-actions .logout")
    const adminButton = $(".auth-actions .admin")

    async function updateAuthButtons() {
        const response = await fetchGet<Account.AuthStatus>("authstatus")

        if (response?.isLoggedIn) {
            logoutButton.css("display", "inline-flex")

            if (response.isAdmin) {
                adminButton.css("display", "inline-flex")
            }
        } else {
            signinButton.css("display", "inline-flex")
            createButton.css("display", "inline-flex")
        }
    }

    updateAuthButtons()

    logoutButton.on("click", async event => {
        event.preventDefault()
        event.stopPropagation()

        try {
            await fetchGet("account/logout")
            window.location.reload()
        } catch (error) {
            console.error("Logout failed", error)
        }
    })
</script>