---
import "../styles/global.css"

interface Props {
    title?: string
}

const { title = "Enfield NH Zoning" } = Astro.props
const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <meta
            name="description"
            content="A community website for discussion, education, and public input on zoning topics in Enfield, New Hampshire."
        />
    </head>
    <body>
        <div class="site-shell">
            <header class="site-header">
                <div>
                    <h1><a href="/">Enfield NH Zoning</a></h1>
                </div>

                <nav class="auth-actions" aria-label="Account actions">
                    {(currentPath == "/sign-in") ? <></> : 
                        <a
                            class="button button-primary button-nav signin"
                            href={`/sign-in${
                                (
                                    currentPath != "/" &&
                                    currentPath != "/complete-sign-in" &&
                                    currentPath != "/sign-in-sent" &&
                                    currentPath != "/sign-up" &&
                                    currentPath != "/sign-up-validation"
                                ) ? `?r=${currentPath}` : ""
                            }`}
                        >
                            <span class="button-icon">&#8618;</span>
                            Sign In
                        </a>
                    }

                    {(currentPath == "/sign-up") ? <></> : 
                        <a class="button button-secondary button-nav create" href="/sign-up">
                            <span class="button-icon">&#10010;</span>
                            Create account
                        </a>
                    }

                    <button class="button button-primary button-nav logout" type="button">
                        <span class="button-icon">&#8617;</span>
                        Logout
                    </button>

                    <a class="button button-secondary button-nav admin" href="/admin/comments">
                        <span class="button-icon">&#9881;</span>
                        Admin
                    </a>
                </nav>
            </header>

            <main class="content-wrap">
                <section class="content-card">
                    <slot />
                </section>
            </main>

            <footer class="site-footer">
                This is an independent website and not an official town website.
            </footer>
        </div>
    </body>
</html>

<script>
    import $ from "jquery"
    import LogRocket from 'logrocket'
    import type { Account } from "@enfield-zoning/website-api-dto"

    import { fetchGet } from "../scripts/fetch"

    const signinButton = $(".auth-actions .signin")
    const createButton = $(".auth-actions .create")
    const logoutButton = $(".auth-actions .logout")
    const adminButton = $(".auth-actions .admin")
    
    LogRocket.init('g4ooym/enfield-nh-zoning')

    async function updateAuthButtons() {
        const response = await fetchGet<Account.AuthStatus>("authstatus")

        if (response?.isLoggedIn) {
            logoutButton.css("display", "inline-flex")

            if (response.isAdmin) {
                adminButton.css("display", "inline-flex")
            }
        } else {
            signinButton.css("display", "inline-flex")
            createButton.css("display", "inline-flex")
        }
    }

    updateAuthButtons()

    logoutButton.on("click", async event => {
        event.preventDefault()
        event.stopPropagation()

        try {
            await fetchGet("account/logout")
            LogRocket.startNewSession()
            window.location.reload()
        } catch (error) {
            console.error("Logout failed", error)
        }
    })
</script>