---
import "../styles/global.css"

interface Props {
    title?: string
}

const { title = "Enfield NH Zoning" } = Astro.props
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <meta
            name="description"
            content="A community website for discussion, education, and public input on zoning topics in Enfield, New Hampshire."
        />
    </head>
    <body>
        <div class="site-shell">
            <header class="site-header">
                <div>
                    <h1>Enfield zoning poll</h1>
                </div>
            </header>

            <main class="content-wrap">
                <section class="content-card">
                    <slot />
                </section>
            </main>

            <footer class="site-footer">
                This is an independent website and not an official town website.
            </footer>
        </div>
    </body>
</html>
